#!/bin/bash

# Grafana Alloy 卸载回调脚本
# 在应用卸载后执行，清理数据

LOG_FILE="${TRIM_PKGVAR}/info.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - [uninstall] $1" >> ${LOG_FILE}
}

if [ "${wizard_data_action:-}" == "delete" ]; then
    rm -rf "${TRIM_PKGVAR}"
    exit 0
fi

log_msg "Uninstall callback completed"
