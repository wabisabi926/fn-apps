#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
SOCKET_PATH="${TRIM_APPDEST}/fn-bluetooth.sock"
PYTHON_BIN="${PYTHON_BIN:-python3}"

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/0}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"

CMD="\"${PYTHON_BIN}\" \"${TRIM_APPDEST}/server/bluetooth.py\" --unix-socket \"${SOCKET_PATH}\" --base-path \"/app/fn-bluetooth\" --www-root \"${TRIM_APPDEST}/www\""

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

ensure_bluetooth_service() {
    if command -v systemctl >/dev/null 2>&1; then
        if ! systemctl is-active --quiet bluetooth.service 2>/dev/null; then
            log_msg "Starting bluetooth.service ..."
            systemctl start bluetooth.service >> ${LOG_FILE} 2>&1 || true
        fi
    fi
}

ensure_user_session() {
    if command -v systemctl >/dev/null 2>&1; then
        if ! systemctl is-active --quiet user@0.service 2>/dev/null; then
            log_msg "Starting user@0.service ..."
            systemctl start user@0.service >> ${LOG_FILE} 2>&1 || true
        fi
    fi
}

ensure_audio_services() {
    if command -v systemctl >/dev/null 2>&1; then
        for svc in pipewire.service pipewire-pulse.service wireplumber.service pulseaudio.service pulseaudio.socket; do
            if systemctl --user list-unit-files "${svc}" >/dev/null 2>&1; then
                if ! systemctl --user is-active --quiet "${svc}" 2>/dev/null; then
                    log_msg "Starting user ${svc} ..."
                    systemctl --user start "${svc}" >> ${LOG_FILE} 2>&1 || true
                fi
            fi
        done
    fi
    local audio_env="XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}"
    if ! env ${audio_env} pactl info >/dev/null 2>&1; then
        if command -v pulseaudio >/dev/null 2>&1; then
            log_msg "Starting pulseaudio in user mode ..."
            if [ ! -f /etc/pulse/default.pa ]; then
                cp /etc/pulse/default.pa.dpkg-new /etc/pulse/default.pa 2>/dev/null || true
            fi
            if [ ! -f /etc/pulse/daemon.conf ]; then
                cp /etc/pulse/daemon.conf.dpkg-new /etc/pulse/daemon.conf 2>/dev/null || true
            fi
            env ${audio_env} pulseaudio --start --fail=false >> ${LOG_FILE} 2>&1 || true
            sleep 1
        elif command -v pipewire >/dev/null 2>&1; then
            log_msg "Starting pipewire daemon ..."
            env ${audio_env} pipewire >> ${LOG_FILE} 2>&1 &
            sleep 1
            if command -v pipewire-pulse >/dev/null 2>&1; then
                log_msg "Starting pipewire-pulse daemon ..."
                env ${audio_env} pipewire-pulse >> ${LOG_FILE} 2>&1 &
            fi
        fi
    fi
}

start_services() {
    log_msg "Ensuring prerequisite services ..."
    ensure_bluetooth_service
    ensure_user_session
    ensure_audio_services
}

cleanup_processes() {
    log_msg "Cleaning up bluetooth-related processes ..."

    pkill -f "bluetoothctl" 2>/dev/null || true
    pkill -f "bt_agent.py" 2>/dev/null || true

    local agent_pid_file="${TRIM_APPDEST}/server/agent.pid"
    if [ -f "${agent_pid_file}" ]; then
        rm -f "${agent_pid_file}"
    fi

    if command -v systemctl >/dev/null 2>&1; then
        systemctl --user stop obex 2>/dev/null || true
    fi
    pkill -x "obexd" 2>/dev/null || true
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "Starting process ..."

    # run cmd to start process
    mkdir -p "${TRIM_PKGVAR}" >/dev/null 2>&1 || true
    rm -f "${SOCKET_PATH}"

    start_services
    setsid bash -c "${CMD}" >> ${LOG_FILE} 2>&1 &
    # write pid to pidfile
    printf "%s" "$!" > ${PID_FILE}
    # log_msg "CMD = ${CMD}"
    # log_msg "pid = $!"
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        
        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            # process not exist, delete pidfile
            rm -f "${PID_FILE}"
            rm -f "${SOCKET_PATH}"
            log_msg "remove pid file 1"
            cleanup_processes
            return
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM ${pid} >> ${LOG_FILE} 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 15 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/15s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
            rm -f "${PID_FILE}"
            rm -f "${SOCKET_PATH}"
            cleanup_processes
        else
            log_msg "process killed... "
            rm -f "${PID_FILE}"
            rm -f "${SOCKET_PATH}"
        fi
    else
        cleanup_processes
    fi

    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0  # process exist
    else
        return 1  # process not exist
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            # Process is not running but pidfile exists - clean it up
            rm -f "${PID_FILE}"
            rm -f "${SOCKET_PATH}"
        fi    
    fi

    return 1
}

case $1 in
start)
    # run start command. exit 0 if success, exit 1 if failed
    start_process
    ;;
stop)
    # run stop command. exit 0 if success, exit 1 if failed
    stop_process
    ;;
status)
    # check application status command. exit 0 if running, exit 3 if not running
    if status; then 
        exit 0
    else 
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
