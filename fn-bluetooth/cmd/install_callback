#!/bin/bash

### This script is called after the user installs the application.

apt-get update -qq

PKGS=""
for pkg in bluez bluez-obexd bluez-tools pulseaudio pulseaudio-utils obexftp python3-dbus python3-gi; do
    if apt-cache show "$pkg" >/dev/null 2>&1 && ! apt list --installed "$pkg" 2>/dev/null | grep -qw 'installed'; then
        PKGS="$PKGS $pkg"
    fi
done

[ -n "$PKGS" ] && apt-get install -y -qq $PKGS 2>/dev/null || true

exit 0
