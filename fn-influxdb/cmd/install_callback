#!/bin/bash

### This script is called after the user installs the application.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_functions"

PORT="${wizard_port:-8086}"
USERNAME="${wizard_username:-admin}"
PASSWORD="${wizard_password:-}"
ORG="${wizard_org:-fnos}"
BUCKET="${wizard_bucket:-default}"
RETENTION="${wizard_retention:-26000h}"
CLI="${wizard_cli:-true}"

mkdir -p "${TRIM_PKGVAR}/bin"
mkdir -p "${TRIM_PKGVAR}/engine"

write_settings "${SETTINGS_FILE}" "${PORT}" "${USERNAME}" "${PASSWORD}" "${ORG}" "${BUCKET}" "${RETENTION}" "${CLI}"

exit 0
