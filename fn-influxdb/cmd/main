#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_functions"

start_app() {
    rotate_log "${LOG_FILE}" 1048576

    if [ ! -x "${INFLUXDB_BIN}" ]; then
        log_msg "InfluxDB binary not found, downloading..."
        download_influxdb || return 1
    fi

    start_process || return 1

    setup_influxdb || true

    ensure_scrutiny_resources || true
}

stop_app() {
    stop_process
}

case $1 in
    start)
        # run start command. exit 0 if success, exit 1 if failed
        start_app
        ;;
    stop)
        # run stop command. exit 0 if success, exit 1 if failed
        stop_app
        ;;
    status)
        # check application status command. exit 0 if running, exit 3 if not running
        if status; then
            exit 0
        else
            exit 3
        fi
        ;;
    *)
        exit 1
        ;;
esac
