#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_functions"

start_app() {
    check_env || return 1

    rotate_log "${LOG_FILE}" 1048576

    if [ ! -f "${SETTINGS_FILE}" ]; then
        local default_schedule
        default_schedule=$(get_cron_schedule 15)
        write_settings "${SETTINGS_FILE}" "8080" "${default_schedule}" "15" "fnOS" "true" "auto" "localhost" "8086" "" "scrutiny" "scrutiny"
    fi

    if ! check_influxdb_running; then
        log_msg "ERROR: InfluxDB is not running. Please start fn-influxdb first."
        return 1
    fi

    ensure_influxdb_bucket || true

    local web_port
    web_port=$(get_web_port)
    local influxdb_host
    influxdb_host=$(get_influxdb_host)
    local influxdb_port
    influxdb_port=$(get_influxdb_port)
    local influxdb_token
    influxdb_token=$(get_influxdb_token)
    local influxdb_org
    influxdb_org=$(get_influxdb_org)
    local influxdb_bucket
    influxdb_bucket=$(get_influxdb_bucket)

    generate_scrutiny_config "${web_port}" "${influxdb_host}" "${influxdb_port}" "${influxdb_token}" "${influxdb_org}" "${influxdb_bucket}"

    apply_translation

    start_process || return 1

    install_cron

    run_collector_once
}

stop_app() {
    remove_cron
    kill_collector
    stop_process
}

case $1 in
    start)
        # run start command. exit 0 if success, exit 1 if failed
        start_app
        ;;
    stop)
        # run stop command. exit 0 if success, exit 1 if failed
        stop_app
        ;;
    status)
        # check application status command. exit 0 if running, exit 3 if not running
        if status; then
            exit 0
        else
            exit 3
        fi
        ;;
    *)
        exit 1
        ;;
esac
