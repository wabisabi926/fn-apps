#!/bin/bash

### This script is called after the user upgrades the application.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_functions"

chmod +x "${COLLECTOR_BIN}" 2>/dev/null
chmod +x "${WEB_BIN}" 2>/dev/null

if [ -f "${SETTINGS_FILE}" ]; then
    saved_port=$(get_web_port)

    if check_influxdb_running; then
        saved_influxdb_host=$(get_influxdb_host)
        saved_influxdb_port=$(get_influxdb_port)
        saved_influxdb_token=$(get_influxdb_token)
        saved_influxdb_org=$(get_influxdb_org)
        saved_influxdb_bucket=$(get_influxdb_bucket)
        generate_scrutiny_config "${saved_port}" "${saved_influxdb_host}" "${saved_influxdb_port}" "${saved_influxdb_token}" "${saved_influxdb_org}" "${saved_influxdb_bucket}"
    fi
fi

rm -f "${TRIM_APPDEST}/web/.translated"
rm -f "${TRIM_APPDEST}/web/.untranslated"

exit 0
