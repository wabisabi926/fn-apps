#!/bin/bash

### This script is called after the user installs the application.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_functions"

WEB_PORT="${wizard_port:-8080}"
HOST_ID="${wizard_host_id:-fnOS}"
CRON_INTERVAL="${wizard_cron_interval:-15}"
CRON_SCHEDULE=$(get_cron_schedule "${CRON_INTERVAL}")
TRANSLATE="${wizard_translate:-true}"
INFLUXDB_MODE="${wizard_influxdb_mode:-auto}"
INFLUXDB_HOST="${wizard_influxdb_host:-localhost}"
INFLUXDB_PORT="${wizard_influxdb_port:-8086}"
INFLUXDB_ORG="${wizard_influxdb_org:-scrutiny}"
INFLUXDB_BUCKET="${wizard_influxdb_bucket:-scrutiny}"

write_settings "${SETTINGS_FILE}" "${WEB_PORT}" "${CRON_SCHEDULE}" "${CRON_INTERVAL}" "${HOST_ID}" "${TRANSLATE}" "${INFLUXDB_MODE}" "${INFLUXDB_HOST}" "${INFLUXDB_PORT}" "" "${INFLUXDB_ORG}" "${INFLUXDB_BUCKET}"

chmod +x "${COLLECTOR_BIN}" 2>/dev/null
chmod +x "${WEB_BIN}" 2>/dev/null

if check_influxdb_running; then
    ensure_influxdb_bucket || true
    generate_scrutiny_config "${WEB_PORT}" "$(get_influxdb_host)" "$(get_influxdb_port)" "$(get_influxdb_token)" "$(get_influxdb_org)" "$(get_influxdb_bucket)"
else
    log_msg "WARNING: InfluxDB is not running. Config will be generated on first start."
fi

exit 0
